APP_ENV=development
HTTP_PORT=8080
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/trading?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
PRICE_STREAM_SYMBOL=BTCUSDT
PRICE_CHANNEL_BUFFER=2048
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10
LATEST_PRICE_TTL=10m
RECENT_HISTORY_MAX_SIZE=200
SHUTDOWN_TIMEOUT=10s
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
